{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Users",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string",
      "maxLength": 255
    },
    "email": {
      "type": "string",
      "maxLength": 255
    },
    "profile": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 255
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "name",
    "email",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false
}
